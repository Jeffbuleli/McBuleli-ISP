# Recommended (with frontend/vercel.json rewrites): do NOT set VITE_API_URL — the app uses same-origin `/api`
# (proxied to Render). No CORS issues, fewer ad-blocker false positives.
#
# For <img src="/api/public/branding-logo/..."> to load when needed, set the real API origin:
VITE_PUBLIC_API_ORIGIN=https://mcbuleli-isp.onrender.com
#
# Avoid setting VITE_API_URL to the public onrender.com URL while the UI is on another domain (e.g. app.mcbuleli.live):
# the build will still prefer `/api` on HTTPS for that case. For a custom API subdomain only:
# VITE_API_URL=https://api.yourdomain.com/api
