# Option A (recommended with frontend/vercel.json): leave unset so the browser calls same-origin `/api`
# (proxied to Render). Logo URLs still need the real API host:
VITE_PUBLIC_API_ORIGIN=https://mcbuleli-isp.onrender.com

# Option B: call the API directly (then set CORS_ORIGINS on the backend for this frontend origin).
# VITE_API_URL=https://mcbuleli-isp.onrender.com/api
