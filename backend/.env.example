PORT=4000
# Set NODE_ENV=production in live deployments (enforces a strong NETWORK_NODE_SECRET_KEY).
NODE_ENV=development
# When behind Nginx/Caddy, set true so rate limits and logs use X-Forwarded-For (client IP).
TRUST_PROXY=false
JWT_SECRET=change_me
DATABASE_URL=postgresql://localhost:5432/postgres
PAWAPAY_WEBHOOK_SECRET=change_me
# SaaS billing (tenants paying you via Pawapay for McBuleli)
PAWAPAY_API_TOKEN=
PAWAPAY_API_BASE_URL=https://api.sandbox.pawapay.io
# Same POST URL for deposits, payouts, refunds — optional shared secret (or inject via proxy)
PAWAPAY_CALLBACK_SECRET=
# Legacy alias; used if PAWAPAY_CALLBACK_SECRET is unset
PAWAPAY_PLATFORM_CALLBACK_SECRET=
# e.g. https://api.yourdomain.com — used by GET /api/webhooks/pawapay to show full callback URL
PUBLIC_API_BASE_URL=
PLATFORM_TRIAL_DAYS=7
PLATFORM_USD_TO_CDF=2800
PLATFORM_SAAS_BILLING_DAYS=30
PLATFORM_PUBLIC_BASE_URL=http://localhost:5173
TID_REMINDER_INTERVAL_MIN=30
NOTIFICATION_WORKER_INTERVAL_SEC=60
NOTIFICATION_MAX_ATTEMPTS=5
# Development: 16+ chars recommended. Production: required unique 32+ chars (not a placeholder string).
NETWORK_NODE_SECRET_KEY=change_me_long_random_secret
# When true, writes radius_radcheck / radius_radreply (same layout as FreeRADIUS PostgreSQL sql module)
# with Cleartext-Password, Simultaneous-Use (from subscription max_simultaneous_devices or plan max_devices),
# Auth-Type, and Mikrotik-Rate-Limit. Point your RADIUS server sql driver at the same database and tables.
FREERADIUS_SYNC_ENABLED=false
# Optional: match stock FreeRADIUS table names (default radius_radcheck / radius_radreply)
# FREERADIUS_TABLE_RADCHECK=radcheck
# FREERADIUS_TABLE_RADREPLY=radreply
# FreeRADIUS accounting → POST /api/webhooks/radius-accounting (JSON body + optional ispId). Required in production.
# RADIUS_ACCOUNTING_WEBHOOK_SECRET=
# Optional overrides (defaults are safe for small ISPs):
# PUBLIC_RL_READ_MAX=120
# PUBLIC_RL_SIGNUP_MAX=10
# PUBLIC_RL_WIFI_INIT_MAX=25
# PUBLIC_RL_WIFI_STATUS_MAX=240
# PUBLIC_RL_SUBSCRIBER_AUTH_MAX=45
BILLING_OVERDUE_INTERVAL_MIN=60
BILLING_OVERDUE_GRACE_HOURS=0
BILLING_RENEWAL_WINDOW_DAYS=7
BILLING_RENEWAL_INTERVAL_MIN=360

# Optional: S3-compatible object storage for ISP branding logos (multi-instance API, CDN-friendly bucket).
# When unset or not "s3", logos stay on local disk under backend/uploads/branding (see BRANDING_UPLOAD_DIR).
# BRANDING_LOGO_STORAGE=s3
# S3_BUCKET=
# S3_REGION=auto
# S3_ENDPOINT=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_FORCE_PATH_STYLE=false
# S3_BRANDING_PREFIX=branding
# BRANDING_UPLOAD_DIR=
