NODE_ENV=production
TRUST_PROXY=true
PORT=4000

# Render PostgreSQL external/internal connection string.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

JWT_SECRET=replace_with_a_long_random_secret
NETWORK_NODE_SECRET_KEY=replace_with_a_unique_32_plus_character_secret

# Public frontend domain used in invite and customer portal links.
PLATFORM_PUBLIC_BASE_URL=https://app.mcbuleli.live

# Public backend URL used in webhook instructions/callback examples.
PUBLIC_API_BASE_URL=https://YOUR_RENDER_SERVICE.onrender.com

# Comma-separated browser origins allowed to call this API.
CORS_ORIGINS=https://app.mcbuleli.live,https://mcbuleli-front.vercel.app

PAWAPAY_API_TOKEN=
PAWAPAY_API_BASE_URL=https://api.sandbox.pawapay.io
PAWAPAY_CALLBACK_SECRET=
PAWAPAY_PLATFORM_CALLBACK_SECRET=
PLATFORM_TRIAL_DAYS=7
PLATFORM_USD_TO_CDF=2800
PLATFORM_SAAS_BILLING_DAYS=30
TID_REMINDER_INTERVAL_MIN=30
NOTIFICATION_WORKER_INTERVAL_SEC=60
NOTIFICATION_MAX_ATTEMPTS=5
FREERADIUS_SYNC_ENABLED=false
BILLING_OVERDUE_INTERVAL_MIN=60
BILLING_OVERDUE_GRACE_HOURS=0
BILLING_RENEWAL_WINDOW_DAYS=7
BILLING_RENEWAL_INTERVAL_MIN=360
